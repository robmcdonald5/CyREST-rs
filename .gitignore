# Generated by Cargo
# will have compiled files and executables
/target/
debug/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# IDE files
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Documentation build
/target/doc/
/target/criterion/

# Test coverage
tarpaulin-report.html
cobertura.xml
lcov.info
*.profraw
*.profdata

# Backup files
*.bak
*.orig

# Temporary files
*.tmp
.temp/

# Environment files
.env
.env.local

# Python virtual environments (if using any Python scripts)
venv/
.venv/
__pycache__/

# Node modules (if using any JS tools)
node_modules/

# Editor directories and files
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# Claude code
*CLAUDE.md
.claude/